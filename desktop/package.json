{
  "name": "ion",
  "version": "1.0.0",
  "description": "Ion — AI-powered developer desktop",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dsswift/ion.git"
  },
  "bugs": {
    "url": "https://github.com/dsswift/ion/issues"
  },
  "homepage": "https://github.com/dsswift/ion#readme",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build --mode production && electron-builder --mac --dir",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "doctor": "bash scripts/doctor.sh",
    "postinstall": "electron-builder install-app-deps && bash scripts/patch-dev-icon.sh && bash scripts/patch-zustand.sh && bash ../scripts/setup-claude-symlinks.sh"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@parcel/watcher": "^2.5.6",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-virtual": "^3.13.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/xterm": "^6.0.0",
    "bonjour-service": "^1.3.0",
    "codemirror": "^6.0.2",
    "diff": "^9.0.0",
    "electron-updater": "^6.6.2",
    "framer-motion": "^12.39.0",
    "immer": "^11.0.0",
    "js-yaml": "^4.2.0",
    "node-pty": "^1.1.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.0",
    "shiki": "^4.1.0",
    "ws": "^8.20.1",
    "zustand": "^5.0.13"
  },
  "build": {
    "appId": "com.sprague.ion.desktop",
    "productName": "Jarvis",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/main/**/*",
      "dist/preload/**/*",
      "dist/renderer/**/*",
      "resources/**/*",
      "!resources/engine/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/engine/ion",
        "to": "engine/ion"
      }
    ],
    "afterPack": "scripts/afterPack.js",
    "mac": {
      "icon": "resources/icon.icns",
      "x64ArchFiles": "**/node_modules/{node-pty/prebuilds/darwin-*/*,@parcel/watcher-darwin-*/**/*}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "notarize": false,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Jarvis uses your microphone to transcribe voice input locally with Whisper.",
        "NSAppleEventsUsageDescription": "Jarvis uses AppleScript to detect available monospace fonts on your system.",
        "NSDesktopFolderUsageDescription": "Jarvis needs access to your Desktop to read and edit project files.",
        "NSDocumentsFolderUsageDescription": "Jarvis needs access to your Documents to read and edit project files.",
        "NSDownloadsFolderUsageDescription": "Jarvis needs access to your Downloads to read and edit project files.",
        "NSLocalNetworkUsageDescription": "Jarvis needs access to your local network to connect to the engine running on a nearby Mac.",
        "NSBonjourServices": [
          "_ion-relay._tcp",
          "_ion._tcp"
        ]
      }
    },
    "dmg": {
      "sign": false
    },
    "afterSign": "scripts/notarize.js",
    "publish": {
      "provider": "github"
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.15",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.2.1",
    "typescript": "^6.0.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.7"
  }
}
